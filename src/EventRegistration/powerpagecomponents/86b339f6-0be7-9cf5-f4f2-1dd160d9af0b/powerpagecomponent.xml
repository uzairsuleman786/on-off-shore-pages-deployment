  <searchcontent>View Registration Detail{% assign id_param = request.params["id"] %}  

{% fetchxml events %}
&lt;fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false"&gt;
  &lt;entity name="er_event"&gt;
    &lt;attribute name="er_eventid" /&gt;
    &lt;attribute name="er_eventname" /&gt;
    &lt;attribute name="createdon" /&gt;
    &lt;attribute name="statuscode" /&gt;
    &lt;attribute name="statecode" /&gt;
    &lt;attribute name="er_seatsavalable" /&gt;
    &lt;attribute name="overriddencreatedon" /&gt;
    &lt;attribute name="owningbusinessunit" /&gt;
    &lt;attribute name="ownerid" /&gt;
    &lt;attribute name="modifiedon" /&gt;
    &lt;attribute name="modifiedonbehalfby" /&gt;
    &lt;attribute name="modifiedby" /&gt;
    &lt;attribute name="er_location" /&gt;
    &lt;attribute name="er_eventdate" /&gt;
    &lt;attribute name="er_description" /&gt;
    &lt;attribute name="createdonbehalfby" /&gt;
    &lt;attribute name="createdby" /&gt;
    &lt;order attribute="er_eventname" descending="false" /&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;

{% endfetchxml %}

{% fetchxml userRegistrationDetails %}

&lt;fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false"&gt;
&lt;entity name="er_registration"&gt;
&lt;attribute name="er_registrationid"/&gt;
&lt;attribute name="er_registrantname"/&gt;
&lt;attribute name="createdon"/&gt;
&lt;attribute name="statuscode"/&gt;
&lt;attribute name="statecode"/&gt;
&lt;attribute name="er_registrationstatus"/&gt;
&lt;attribute name="er_registrationdate"/&gt;
&lt;attribute name="overriddencreatedon"/&gt;
&lt;attribute name="owningbusinessunit"/&gt;
&lt;attribute name="ownerid"/&gt;
&lt;attribute name="modifiedon"/&gt;
&lt;attribute name="modifiedonbehalfby"/&gt;
&lt;attribute name="modifiedby"/&gt;
&lt;attribute name="er_event"/&gt;
&lt;attribute name="er_email"/&gt;
&lt;attribute name="createdonbehalfby"/&gt;
&lt;attribute name="createdby"/&gt;
&lt;attribute name="er_registeredby"/&gt;
 
&lt;order attribute="er_registrantname" descending="false"/&gt;

   &lt;filter type ="and"&gt;
      &lt;condition attribute="er_registrationid" operator="eq" value="{{id_param}}" /&gt;
    &lt;/filter&gt;

&lt;/entity&gt;
&lt;/fetch&gt;

{% endfetchxml %}


&lt;div class="container"
style="display: flex; flex-wrap: wrap; background-color: Irgba(255, 255, 255, 0.8); border-radius: 10px; box-shadow: 4px 8px [ &lt;div class="col-lg-12 columnBlockLayout"
style="flex-grow: 1; display: flex; flex-direction: column; min-width: 250px;"&gt;
&lt;form id="courseForm"&gt;
  &lt;div class="row"&gt;

    &lt;h2 class="h2 mb-0"&gt;Event Registration Detail&lt;/h2&gt;
  &lt;/div&gt;
{% if userRegistrationDetails.results.entities.size&gt; 0 %}
{% assign userRegistration = userRegistrationDetails.results.entities[0] %}
&lt;div class="form-group mb-3"&gt;&lt;label for="name" class="form-label"&gt;Registrant Name: &lt;/label&gt;
&lt;input type="text" id="name" name="name" required="" class="form-control" value="{{userRegistration.er_registrantname}}" disabled/&gt;&lt;/div&gt; 
&lt;div class="form-group mb-3"&gt;&lt;label for="email" class="form-label"&gt;Email: &lt;/label&gt; &lt;input type="text"
id="email" name="email" required="" class="form-control" value="{{userRegistration.er_email}}" disabled/&gt;&lt;/div&gt; 
&lt;div class="form-group mb-3"&gt; &lt;label for="registrationstatus" class="form-label"&gt;Registration Status: &lt;/label&gt;
&lt;input type="text" id="registrationStatus" name="registrationStatus" required="" class="form-control" value="{{userRegistration.er_registrationstatus.label}}"disabled/&gt;&lt;/div&gt; 
 &lt;div class="form-group mb-3"&gt;{{userRegistration.er_event.value}}
&lt;label for="eventRegister" class="form-label"&gt;Event Name: &lt;/label&gt;
&lt;input type="text"
id="eventRegister" name="eventRegister" required="" class="form-control" value="{{userRegistration.er_event.name}}" disabled/&gt;
&lt;/div&gt;
{% endif %}
&lt;/form&gt;
&lt;/div&gt;
&lt;/div&gt;View Registration Detail</searchcontent>
