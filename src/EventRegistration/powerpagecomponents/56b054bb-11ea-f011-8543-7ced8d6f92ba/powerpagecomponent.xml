  "source": "&lt;div class=\"login-page py-1\"&gt;\r\n  &lt;div class=\"container\"&gt;\r\n    &lt;div class=\"row justify-content-between\"&gt;\r\n      &lt;div class=\"col-12 col-md-12 col-lg-6\"&gt;\r\n        &lt;div class=\"d-flex flex-column align-items-start h-100 \"&gt;\r\n          &lt;div class=\"p-4\"&gt;\r\n            &lt;img src=\"/logo-dark.png\" alt=\"\"&gt;\r\n          &lt;/div&gt;\r\n          &lt;div class=\"d-flex justify-content-center login-form\"&gt;\r\n            &lt;div class=\"col-12 col-lg-8\"&gt;\r\n              &lt;h1 class=\"fs-4 mb-3\"&gt;Sign In&lt;/h1&gt;\r\n              &lt;button class=\"btn btn-outline-primary  w-100\" onclick=\"triggerBeazleySignIn()\"&gt; Beazley Account &lt;/button&gt;\r\n              &lt;div class=\"signin-divider d-flex justify-content-center\"&gt;\r\n                &lt;p class=\"mb-0 p-3 bg-white text-gray\"&gt;Sign in Using&lt;/p&gt;\r\n              &lt;/div&gt;\r\n \r\n              &lt;button class=\"btn btn-outline-secondary  w-100 mb-4\" onclick=\"triggerGoogleSignIn()\"&gt;\r\n                &lt;div class=\"d-flex gap-3 justify-content-center\"&gt;\r\n                  &lt;img src=\"/google.png\" alt=\"\"&gt;\r\n                  &lt;span class=\"fw-bold\"&gt;Google &lt;/span&gt;\r\n                &lt;/div&gt;\r\n \r\n              &lt;/button&gt;\r\n              &lt;button class=\"btn btn-outline-secondary  w-100\" onclick=\"triggerMicrosoftSignIn()\"&gt;\r\n                &lt;div class=\"d-flex gap-3 justify-content-center\"&gt;\r\n                  &lt;img src=\"/microsoft.png\" alt=\"\"&gt;\r\n                  &lt;span class=\"fw-bold\"&gt;Microsoft &lt;/span&gt;\r\n                &lt;/div&gt;\r\n              &lt;/button&gt;\r\n \r\n            &lt;/div&gt;\r\n \r\n          &lt;/div&gt;\r\n        &lt;/div&gt;\r\n \r\n \r\n \r\n      &lt;/div&gt;\r\n      &lt;div class=\"col-12 col-md-12 col-lg-5\"&gt;\r\n        &lt;div class=\"img-wrapper rounded\"&gt;\r\n          &lt;div class=\"login-slide-sec h-100 p-4 py-5\"&gt;\r\n            &lt;div class=\"right-content rounded d-flex align-items-center flex-wrap\"&gt;\r\n              &lt;h1 class=\"fs-2 text-primary-dark mb-0 fw-bold\"&gt;\r\n                Manage all your&lt;br /&gt;\r\n                Request with ease!\r\n              &lt;/h1&gt;\r\n              &lt;img src=\"/cards.png\" class=\"img-fluid\" alt=\"Sign In\"&gt;\r\n            &lt;/div&gt;\r\n          &lt;/div&gt;\r\n        &lt;/div&gt;\r\n      &lt;/div&gt;\r\n    &lt;/div&gt;\r\n  &lt;/div&gt;\r\n \r\n \r\n \r\n&lt;/div&gt;\r\n&lt;script&gt;\r\n  function triggerGoogleSignIn() {\r\n    document.getElementById('Google').click();\r\n  }\r\n  function triggerMicrosoftSignIn() {\r\n    document.getElementById('Microsoft').click();\r\n  }\r\n  function triggerBeazleySignIn() {\r\n    window.location.href = \"https://login.windows.net/9a50eba8-7568-447a-bcb9-27a0d464aa80/\";\r\n  }\r\n \r\n&lt;/script&gt;"
